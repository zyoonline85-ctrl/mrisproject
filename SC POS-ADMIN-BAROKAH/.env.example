# Pilihan mode API:
# - local: pakai backend lokal, default http://localhost:4000/api atau host browser saat ini port 4000
# - remote/base_url: pakai VITE_REMOTE_API_BASE_URL
# - custom: isi langsung VITE_API_BASE_URL untuk override manual
VITE_API_MODE=remote
VITE_API_BASE_URL=
# Kosongkan agar local otomatis mengikuti host admin saat ini dengan port 4000.
# Contoh kalau mau paksa local: VITE_LOCAL_API_BASE_URL=http://localhost:4000/api
VITE_LOCAL_API_BASE_URL=
# VITE_REMOTE_API_BASE_URL=https://pos-barokah-api.mesproject.id/api
VITE_SHOW_DEMO_HINTS=false
