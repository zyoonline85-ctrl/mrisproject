NODE_ENV=development
DATA_MODE=mock
PORT=4000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_barokah
DB_CONNECTION_LIMIT=10

# Auth
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=1d

# CORS
# Backend membaca .env lalu .env.local. Jika keduanya ada, .env.local menang.
# Isi origin frontend yang boleh akses API, pisahkan dengan koma.
# Development cepat boleh pakai CORS_ORIGIN=*
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:4000
TELEGRAM_LOG_ENABLED=true
TELEGRAM_BOT_TOKEN=isi-token-bot
TELEGRAM_CHAT_ID=isi-chat-id
TELEGRAM_LOG_TIMEOUT_MS=2500