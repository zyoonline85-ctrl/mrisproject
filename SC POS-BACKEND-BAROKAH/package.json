{
  "name": "pos-backend-barokah",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API POS Barokah Group built with Express CommonJS, MySQL, Knex, and Swagger.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "seed:clean": "SEED_MODE=clean knex seed:run",
    "seed:demo": "SEED_MODE=demo knex seed:run",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run",
    "db:reset:clean": "knex migrate:rollback --all && knex migrate:latest && SEED_MODE=clean knex seed:run",
    "db:reset:demo": "knex migrate:rollback --all && knex migrate:latest && SEED_MODE=demo knex seed:run",
    "audit:mysql-boundary": "node scripts/audit-mysql-mock-boundary.js",
    "test": "vitest run"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
